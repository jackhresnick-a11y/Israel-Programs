// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DurationType {
  TEN_DAY
  SHORT
  SUMMER
  SEMESTER
  GAP_YEAR
  MULTI_YEAR
  ONGOING
  /// Retired 2026-07-12 taxonomy pass -- no programs use this value anymore, kept in
  /// the enum (Postgres can't drop enum values in place) rather than force a data
  /// migration on any external reference. New programs should never be assigned CUSTOM.
  CUSTOM
}

enum ProgramStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum EditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactRequestStatus {
  AWAITING_ALUMNUS
  APPROVED
  DECLINED
  EXPIRED
}

/// AUTO is the default: the public reference list follows ReferenceConfig.unlockedAt /
/// the live approved count (see lib/referenceVisibility.ts's resolveReferenceVisibility).
/// FORCE_SHOW/FORCE_HIDE are the admin escape hatch in either direction.
enum ReferenceVisibility {
  AUTO
  FORCE_SHOW
  FORCE_HIDE
}

enum TravelType {
  SINGLE_LOCATION
  MULTI_CITY_TOURING
}

enum FieldDecisionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EmailVerificationStatus {
  VERIFIED
  BOUNCED
  WRONG_CONTACT
}

enum WebsiteLanguage {
  ENGLISH
  HEBREW
  BOTH
}

enum OutreachStatus {
  DRAFT
  APPROVED
  SENT
  BOUNCED
  REPLIED
  WRONG_CONTACT
}

enum SchoolSize {
  BIG
  SMALL
}

enum CounselorOutreachStatus {
  NOT_CONTACTED
  CONTACTED
  REPLIED
  BOUNCED
  WRONG_CONTACT
}

enum PollQuestionType {
  STARS
  RADIO
  DROPDOWN
}

enum PollLifecycleStatus {
  ACTIVE
  RETIRED
}

/// EVALUATIVE: higher is better (Overall, Recommend, Mentorship). DESCRIPTIVE: the
/// number describes how much of something, not a grade -- low is not bad (e.g. "how
/// much did experience depend on staff"). Drives whether results show a star + mean
/// (EVALUATIVE) or a neutral spectrum position + endpoint labels, no star
/// (DESCRIPTIVE). Default EVALUATIVE so every existing question is unaffected until
/// an admin reclassifies it.
enum PollScaleType {
  EVALUATIVE
  DESCRIPTIVE
}

enum PollResponseStatus {
  /// Vestigial -- no new response is ever written PENDING since the after-submit email
  /// verification step was removed (see FLAGGED below). Kept because Postgres can't
  /// drop an enum value in place, same posture as DurationType.CUSTOM.
  PENDING
  COUNTED
  /// An anonymous link submission that tripped an anti-abuse signal at submit time
  /// (repeat ipHash, repeat browser cookie, token over cap/revoked/expired) -- not in
  /// public math until an admin approves it in /admin/polls/moderation. Replaces the
  /// old PENDING-awaiting-email-click state; nothing sits waiting on an email anymore.
  FLAGGED
  VOIDED
}

enum PollCompletion {
  FULL
  PARTIAL
  DROPPED
}

enum PollDisplayFormat {
  STARS
  PERCENT
  BOTH
}

enum PollReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Moderation status for the standalone `Review` model -- same PENDING-first,
/// nothing-auto-approves, reject-never-deletes posture as PollReviewStatus, kept as its
/// own enum (not a reuse of ProgramStatus) since a Review's moderation lifecycle is a
/// separate concern from a Program's publish lifecycle even though the value sets
/// happen to match.
enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum ProgramFaqStatus {
  DRAFT
  PUBLISHED
  REJECTED
}

model Program {
  id                     String                     @id @default(cuid())
  name                   String
  slug                   String                     @unique
  description            String
  goodFor                String?
  logoUrl                String?
  organization           String?
  organizationId         String?
  organizationRef        Organization?              @relation(fields: [organizationId], references: [id])
  location               String?
  durationType           DurationType
  durationText           String?
  cost                   String?
  signupInstructions     String?
  signupUrl              String?
  contactEmail           String?
  contactEmailSource     String?
  contactEmailVerifiedAt DateTime?
  /// Current verification state of contactEmail. Null means never checked (or reset
  /// because contactEmail's value changed since the last check) -- see
  /// ContactEmailVerification for the append-only history and lib/emailVerification.ts
  /// for the queue/staleness logic. This field is a workflow/QA signal, not proposable
  /// program content -- it's deliberately excluded from the ProgramEdit field-decision
  /// pipeline (NULLABLE_ENUM_FIELDS in lib/programEdits.ts) and only ever written by the
  /// admin-only email-verification action.
  contactEmailStatus     EmailVerificationStatus?
  contactPhone           String?
  contactWebsite         String?
  /// Detected language of contactWebsite/signupUrl, for the admin bulk-email tool's
  /// English/Hebrew/Both sections (see lib/programs.ts's listProgramContactEmails and
  /// prisma/classify-website-language.ts, which does the one-time detection pass).
  /// Admin-only workflow signal, not proposable program content -- same reasoning as
  /// contactEmailStatus above, so it's excluded from the ProgramEdit field-decision
  /// pipeline and only ever written by the admin-only website-language route.
  websiteLanguage        WebsiteLanguage?
  /// Manual override for the admin outreach tool's category grouping (see
  /// lib/outreachCategories.ts's categorizeProgram, which uses this value when set
  /// and falls back to heuristic rules over tags/websiteLanguage/durationType/name
  /// when null). A plain string (validated against the category-key union at the API
  /// layer, app/api/admin/programs/[id]/outreach-category/route.ts) rather than a
  /// Postgres enum on purpose -- these categories are admin-workflow labels expected
  /// to be renamed/split as the outreach tool evolves, and a string column makes that
  /// a code change instead of a migration each time. Same ownership boundary as
  /// websiteLanguage/contactEmailStatus above: admin-only, not proposable content.
  outreachCategory       String?
  hasScholarship         Boolean?
  hasCollegeCredit       Boolean?
  travelType             TravelType?
  /// Internal moderator-only note (e.g. "no dedicated website found during research,
  /// verify before relying on this entry") -- never selected into any public page or
  /// client-component props, only shown on the admin program view. Not proposable
  /// content: no ProgramEdit field-decision path touches it.
  adminNote              String?
  status                 ProgramStatus              @default(PENDING)
  createdById            String
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  tags                   Tag[]                      @relation("ProgramTags")
  videos                 Video[]
  reviews                Review[]
  edits                  ProgramEdit[]
  references             Reference[]
  referenceConfig        ReferenceConfig?
  emailVerifications     ContactEmailVerification[]
  outreachEmail          OutreachEmail?
  folderItems            FolderItem[]
  pollConfig             ProgramPollConfig?
  pollResponses          PollResponse[]
  referrerTokens         ReferrerToken[]
  pollReviews            PollReview[]
  faqs                   ProgramFAQ[]

  @@index([durationType])
  @@index([status])
  @@index([organizationId])
}

/// One outreach ("verify your listing") draft/send record per program -- @unique
/// programId means regenerating drafts upserts in place rather than piling up rows.
/// toEmail snapshots Program.contactEmail at draft time so send-batch can detect (and
/// refuse to send against) a contactEmail that changed after approval. Status only
/// ever advances via the admin-gated routes in app/api/admin/outreach/* or the
/// signature-verified Resend bounce webhook -- never touched by import/seed code,
/// same ownership boundary as contactEmailStatus above.
model OutreachEmail {
  id                String         @id @default(cuid())
  programId         String         @unique
  program           Program        @relation(fields: [programId], references: [id])
  status            OutreachStatus @default(DRAFT)
  toEmail           String
  /// True once an admin hand-edits toEmail away from the program's real contactEmail
  /// (e.g. redirecting a test draft to their own inbox). send-batch's drift guard
  /// normally reverts a row to DRAFT if toEmail no longer matches the program's
  /// current contactEmail -- this flag distinguishes "admin did this on purpose" from
  /// "the contact email changed underneath the draft," so an overridden row is still
  /// allowed to send to its overridden address instead of being silently reverted.
  toEmailOverridden Boolean        @default(false)
  subject           String
  body              String
  /// True once an admin hand-edits subject/body -- generateDrafts() skips
  /// regenerating a row with edited: true so a hand-tuned draft is never clobbered.
  edited            Boolean        @default(false)
  approvedById      String?
  approvedAt        DateTime?
  sentAt            DateTime?
  /// Resend's message id, set on send -- correlates the bounce webhook back to a row.
  resendId          String?        @unique
  note              String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
}

/// A named, reusable outreach email (subject + body) an admin can save and pick from
/// when generating drafts -- distinct from the single global template stored in
/// SiteContent (outreachSubjectTemplate/outreachBodyTemplate), which remains the
/// fallback "Default" option. Supports the same {mergeField} syntax as the global
/// template (see lib/outreach.ts's renderOutreachTemplate) -- rendering is identical,
/// only the source of subject/body differs.
model OutreachTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Append-only log of human verification actions on Program.contactEmail. Snapshots the
/// address as it was at check time, so a bounced/replaced address and its reason survive
/// any later edit to Program.contactEmail. Cascade on program delete is fine here (unlike
/// ProgramExportRow) -- history of a deleted program's email has no standalone value.
model ContactEmailVerification {
  id          String                  @id @default(cuid())
  programId   String
  program     Program                 @relation(fields: [programId], references: [id], onDelete: Cascade)
  email       String
  status      EmailVerificationStatus
  note        String?
  checkedById String
  checkedAt   DateTime                @default(now())

  @@index([programId])
}

/// Umbrella organization contact info, distinct from Program.organization (a free-text
/// display label). Only populated for organizations whose own contact address is shared
/// across multiple, otherwise-distinct programs (e.g. several Mechinat-* programs all
/// pointing at the Joint Council of Pre-Military Academies' front desk) -- writing that
/// same address onto every Program.contactEmail row would look like duplicated/broken
/// data and isn't a program-specific contact. Program.contactEmail stays null for any
/// program whose only known email is here.
model Organization {
  id                 String    @id @default(cuid())
  name               String    @unique
  contactEmail       String?
  contactEmailSource String?
  programs           Program[]
}

model ProgramEdit {
  id             String                     @id @default(cuid())
  programId      String
  program        Program                    @relation(fields: [programId], references: [id], onDelete: Cascade)
  payload        String
  submittedById  String
  status         EditStatus                 @default(PENDING)
  createdAt      DateTime                   @default(now())
  reviewedAt     DateTime?
  fieldDecisions ProgramEditFieldDecision[]

  @@index([programId])
  @@index([status])
}

/// One row per changed field on a ProgramEdit, seeded from the computed diff
/// the first time a moderator opens the review screen. Tag adds/removes reuse
/// this same shape via a "tag:added:<slug>" / "tag:removed:<slug>" fieldName
/// convention rather than a second parallel structure. finalValue defaults to
/// proposedValue but a moderator can overwrite it before accepting.
model ProgramEditFieldDecision {
  id            String              @id @default(cuid())
  editId        String
  edit          ProgramEdit         @relation(fields: [editId], references: [id], onDelete: Cascade)
  fieldName     String
  proposedValue String?
  finalValue    String?
  decision      FieldDecisionStatus @default(PENDING)

  @@unique([editId, fieldName])
}

model Tag {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  category String?
  /// Display order within its category (ascending), for both the filter-bar dropdowns
  /// and the program-form tag picker. Ties (e.g. the default 0 most tags are created
  /// with) break by name -- see listAllTags's orderBy.
  order    Int       @default(0)
  programs Program[] @relation("ProgramTags")
}

/// Admin-editable registry of the category headers tags are grouped under (both in the
/// browse-page filter bar and the program-form tag picker). `Tag.category` is a soft
/// string reference to `TagCategory.slug` -- deliberately not a foreign key, so existing
/// tags and the OR-within/AND-across grouping in lib/programs.ts's buildTagAndClauses
/// keep working unchanged even for a category that has since been renamed or removed.
/// Duration and Region are NOT rows here -- Duration is a real Program column
/// (durationType) and Region is a pure UI-layer grouping over `location`-category tags
/// (see lib/regions.ts) -- neither is a Tag category. They have their own admin-editable
/// tables below (DurationOption, Region) instead.
model TagCategory {
  id           String  @id @default(cuid())
  slug         String  @unique
  label        String
  order        Int     @default(0)
  tint         String  @default("accent")
  showInFilter Boolean @default(true)
}

/// Admin-editable display config + order + filter visibility for each DurationType enum
/// value. The enum itself stays the source of truth for *which* durations exist and for
/// Program.durationType; this table only overrides label/order/visibility. `label` here is
/// the single source of truth for how a duration renders everywhere once seeded (see
/// lib/duration.ts's getDurationLabelMap) -- the static DURATION_LABELS map becomes the
/// seed default + fallback for any value missing a row.
model DurationOption {
  id           String       @id @default(cuid())
  value        DurationType @unique
  label        String
  order        Int          @default(0)
  showInFilter Boolean      @default(true)
}

/// Admin-editable replacement for lib/regions.ts's hardcoded REGION_TO_SLUGS. A region is
/// a named grouping of existing `location`-category Tag slugs; selecting it in the browse
/// filter bar toggles all of memberSlugs in the `tags` param, riding the same
/// buildTagAndClauses OR-within-category logic as any other location tag (no new filter
/// param, no Program schema change). memberSlugs is a soft reference to Tag.slug, same
/// spirit as TagCategory.slug -- not a foreign key, so a deleted/renamed tag just drops
/// silently out of the region rather than blocking the delete.
model Region {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  order       Int      @default(0)
  memberSlugs String[]
}

model Video {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  caption   String?
  createdAt DateTime @default(now())
}

/// Standalone star + free-text reviews -- the "just write a review" path that doesn't
/// require going through the /rate poll flow. Moderated the same way PollReview is:
/// PENDING by default, nothing auto-publishes, REJECTED rows are retained (never
/// deleted). `reviewerName`/`userId` are always captured regardless of `isAnonymous` --
/// moderation needs to see who wrote it even when the public display doesn't (same
/// "capture internally, display per choice" split as PollResponse.ipHash). Public reads
/// must select `reviewerName` only when `!isAnonymous`, and must never select `userId`
/// -- same RSC-payload-leak discipline as every other public/sensitive-split model.
model Review {
  id            String       @id @default(cuid())
  programId     String
  program       Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  rating        Int
  text          String
  reviewerName  String
  userId        String?
  isAnonymous   Boolean      @default(false)
  status        ReviewStatus @default(PENDING)
  moderatedBy   String?
  moderatedAt   DateTime?
  moderatorNote String?
  createdAt     DateTime     @default(now())

  @@index([programId, status])
  @@index([status])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  body      String
  updatedAt DateTime @updatedAt
}

model Reference {
  id                   String           @id @default(cuid())
  programId            String
  program              Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId               String
  displayName          String
  attendedText         String
  note                 String?
  contactEmail         String
  /// Normalized E.164 (e.g. "+972501234567"). Gated identically to
  /// contactEmail -- never selected into listPublishedReferences or any
  /// public/requester-facing payload. Admin-only.
  whatsappNumber       String?
  /// Required whenever whatsappNumber is set (enforced in code, not the DB) --
  /// same provenance principle as Program.contactEmailSource.
  whatsappNumberSource String?
  status               ProgramStatus    @default(PENDING)
  /// Consent to be listed publicly and to receive contact requests, captured at
  /// submission time. Existing rows predate this field and stay `false` -- they were
  /// already PUBLISHED before consent existed, so this is not backfilled or enforced
  /// retroactively (no DB CHECK, unlike PollReview's consentGiven, for that reason).
  consentGiven         Boolean          @default(false)
  consentAt            DateTime?
  createdAt            DateTime         @default(now())
  contactRequests      ContactRequest[]

  @@unique([programId, userId])
  @@index([programId])
  @@index([status])
}

model ContactRequest {
  id              String               @id @default(cuid())
  referenceId     String
  reference       Reference            @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  requesterUserId String
  requesterEmail  String
  /// Snapshotted from Clerk at request time (same "a changed value shouldn't rewrite
  /// history" precedent as OutreachEmail.toEmail) -- not re-derived from Clerk at
  /// approve/decline/reminder time, so a later name change or account deletion never
  /// breaks the intro/reminder emails.
  requesterName   String
  note            String?
  /// Single-use secret embedded in the alumnus's approve/decline email links --
  /// randomBytes(24).base64url, same generation as ReferrerToken.token /
  /// Folder.shareToken. Never sent to the requester's client.
  token           String               @unique
  status          ContactRequestStatus @default(AWAITING_ALUMNUS)
  createdAt       DateTime             @default(now())
  resolvedAt      DateTime?
  /// Set the one time the 3-day reminder email fires, so it can never fire twice.
  reminderSent    Boolean              @default(false)

  @@unique([referenceId, requesterUserId])
  @@index([referenceId])
  @@index([status, createdAt])
}

/// Per-program admin override for the Alumni References public list, mirroring
/// ProgramPollConfig's "1:1, missing row reads as schema defaults" shape. AUTO is the
/// default -- see the ReferenceVisibility enum doc comment and
/// lib/referenceVisibility.ts's resolveReferenceVisibility for the resolution logic.
/// unlockedAt is written once, by lib/references.ts's approveReference, the first time
/// the program's approved-reference count reaches minToShow -- this is what makes the
/// public list *sticky* once unlocked (a later drop in count never re-hides it).
model ReferenceConfig {
  programId  String              @id
  program    Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  visibility ReferenceVisibility @default(AUTO)
  unlockedAt DateTime?
  minToShow  Int                 @default(3)
}

/// Immutable, append-only log powering the admin xlsx export. Deliberately
/// has no foreign key to Program: a row here must survive even if the
/// underlying program is later renamed or deleted, since it's a permanent
/// historical record, not a live view of the Program table.
model ProgramExportRow {
  id        String   @id @default(cuid())
  programId String   @unique
  name      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Site-wide footer "ask us" submission. Anonymous by design -- no Clerk
/// user relation, no IP stored. `path` is the page the visitor submitted
/// from (display-only provenance for the admin list), not used for routing.
model Lead {
  id        String   @id @default(cuid())
  email     String
  message   String?
  path      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Outreach contact for an Israel-guidance counselor at a Jewish school abroad --
/// entirely separate from Program (these are schools, not programs). sourceUrl is
/// required: no email is ever entered without a page it was observed on, same
/// provenance principle as Program.contactEmailSource. emailIsGeneric flags a
/// generic school address (info@/office@) captured in lieu of a counselor-specific
/// one -- never presented as a direct counselor contact. Status only ever advances
/// via recordCounselorOutreach (lib/counselorContacts.ts), which also appends a
/// CounselorContactEvent row -- same audit-log shape as ContactEmailVerification.
model CounselorContact {
  id             String                  @id @default(cuid())
  schoolName     String
  country        String
  cityRegion     String
  schoolSize     SchoolSize?
  contactName    String?
  email          String
  emailIsGeneric Boolean                 @default(false)
  sourceUrl      String
  notes          String?
  status         CounselorOutreachStatus @default(NOT_CONTACTED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  events         CounselorContactEvent[]

  @@unique([schoolName, country])
  @@index([country])
  @@index([status])
  @@index([createdAt])
}

/// Append-only log of outreach status changes on a CounselorContact. Snapshots the
/// email as it was at the time of the change, so a bounced address and the reason
/// survive any later edit to CounselorContact.email. Cascade on delete is fine --
/// history of a deleted contact's outreach has no standalone value.
model CounselorContactEvent {
  id           String                  @id @default(cuid())
  contactId    String
  contact      CounselorContact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  email        String
  status       CounselorOutreachStatus
  note         String?
  recordedById String
  createdAt    DateTime                @default(now())

  @@index([contactId])
}

/// Anonymous usage counters for the programs browse page -- which filter
/// values get selected and what people search for (including zero-result
/// queries). No userId, no IP, no cookies: this is a counter, not a
/// per-visitor log. Written fire-and-forget via lib/analytics.ts's after()
/// wrapper so a write failure never blocks or slows a page response.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
}

/// A user's named list of programs -- replaces the flat favorites/SavedItem
/// concept sketched in docs/PRODUCT_SPEC.md §3 (never build that; every save
/// action here targets a Folder, with a lazily-created isDefault one giving
/// the one-tap "save" UX). shareToken is null until the owner shares the
/// folder; sharing always mints a fresh random token (see lib/folders.ts's
/// mintShareToken) rather than toggling a boolean, so a revoked link can
/// never be resurrected by re-sharing. There is deliberately no separate
/// Share model -- one live link per folder is enough for v1.
model Folder {
  id         String       @id @default(cuid())
  ownerId    String
  name       String
  isDefault  Boolean      @default(false)
  shareToken String?      @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  items      FolderItem[]

  @@index([ownerId])
}

/// One (folder, program) membership. onDelete: SetNull (not Cascade) on the
/// program relation is deliberate: if a program is hard-deleted, its
/// FolderItem row survives as a tombstone (programId null) rather than
/// vanishing, so the "N programs no longer available" count shown to a
/// folder's owner and to shared-link visitors stays accurate for both
/// hard-deleted and merely-unpublished programs, not just one of the two.
/// Tombstones are inert (nothing writes a null programId except this
/// cascade) and never count against MAX_ITEMS_PER_FOLDER; they persist
/// until the owner clears them (lib/folders.ts's clearUnavailableItems).
model FolderItem {
  id        String   @id @default(cuid())
  folderId  String
  programId String?
  createdAt DateTime @default(now())
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@unique([folderId, programId])
}

/// One rateable question in the alumni-ratings system. `labels` always holds exactly
/// five entries (index 0 = value 1), validated in lib/pollShared.ts's zod schema, not
/// the DB. Questions are retired, never deleted, once any PollAnswer references them
/// (see the Restrict relation below) -- editing `text` on a question that already has
/// answers bumps `version` in the same write (lib/pollQuestions.ts's updateQuestion),
/// so historical answers stay attributable to the wording they were actually given
/// under (PollAnswer.questionVersion snapshots it at answer time).
model PollQuestion {
  id              String              @id @default(cuid())
  key             String              @unique
  text            String
  type            PollQuestionType
  labels          String[]
  dropdownOptions Json?
  status          PollLifecycleStatus @default(ACTIVE)
  scaleType       PollScaleType       @default(EVALUATIVE)
  version         Int                 @default(1)
  answers         PollAnswer[]
  reviews         PollReview[]
}

/// A named, ordered group of questions shown together on the rating form. `questionIds`
/// is an ordered soft reference to PollQuestion.id -- same "soft ref, not a foreign key"
/// shape as Region.memberSlugs, so a retired/deleted question just needs scrubbing from
/// this array rather than blocking on a relation. Exactly one bucket ever has
/// `isCore: true` (enforced in lib/pollQuestions.ts, not the DB) -- the Core bucket's
/// questions are the fixed 5-question set every program always carries and can never be
/// detached (see ProgramPollConfig.bucketIds below); every other bucket is optional,
/// per-program, presentation-only grouping over the same PollAnswer rows.
model QuestionBucket {
  id          String              @id @default(cuid())
  name        String
  description String?
  questionIds String[]
  order       Int                 @default(0)
  isCore      Boolean             @default(false)
  status      PollLifecycleStatus @default(ACTIVE)
}

/// Auto-attaches `bucketId` to every program carrying ALL of `tagSlugs` (ANDed, at
/// least two conditions -- enforced in lib/pollBucketRules.ts, not the DB). Both fields
/// are soft references (same posture as Region.memberSlugs / QuestionBucket.questionIds
/// elsewhere in this schema): a rule pointing at a deleted bucket or a dead tag slug
/// simply attaches nothing rather than breaking resolution. This is additive to Core and
/// to a program's manually-attached `ProgramPollConfig.bucketIds` -- see
/// lib/pollConfig.ts's getQuestionsForProgram, which merges rule-attached bucket ids in
/// before calling the pure resolver, so removedQuestionIds/retired-bucket/dead-id
/// handling there apply identically regardless of how a bucket got attached. Retire,
/// don't delete -- a RETIRED rule stops attaching but its row (and the responses already
/// collected against the bucket while it applied) stay untouched; there is no delete path.
model BucketAttachmentRule {
  id        String              @id @default(cuid())
  bucketId  String
  tagSlugs  String[]
  status    PollLifecycleStatus @default(ACTIVE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

/// Per-program poll settings -- one row per Program, created by prisma/seed-polls.ts for
/// every existing program and by admin config edits for new ones (a missing row reads as
/// the schema defaults via lib/pollConfig.ts's getProgramPollConfig, so a program created
/// after the seed still degrades gracefully rather than 500ing). `bucketIds` holds only
/// *extra*, non-core buckets -- the Core bucket applies to every program implicitly and
/// is never stored here, which is how "the Core bucket cannot be removed from any
/// program" is enforced at both the admin UI (no control ever offers it) and the API
/// layer (no field exists to express removing it). `removedQuestionIds` can still
/// suppress an individual core (or added) question for just this program;
/// `addedQuestionIds` are per-program one-off additions outside any bucket.
model ProgramPollConfig {
  programId             String            @id
  program               Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  bucketIds             String[]
  addedQuestionIds      String[]
  removedQuestionIds    String[]
  resultsVisible        Boolean           @default(false)
  minResponsesToPublish Int               @default(7)
  displayFormat         PollDisplayFormat @default(STARS)
  placeholderOverride   String?
  /// Governs *capture*, not results -- deliberately independent of resultsVisible and
  /// the global kill switch (which gate the score/reviews). Default off. Flipping this
  /// on lazily mints one designated ReferrerToken (label "Public program page",
  /// uncapped, no expiry) the first time, stored in publicTokenId -- re-toggling
  /// off/on reuses the same token rather than minting a fresh one each time, so its
  /// accumulated response history in /admin/polls/links stays attached to one row.
  /// lib/pollConfig.ts's getPublicPollLink is the only reader that should build a
  /// public-facing URL from this.
  pollLinkPublic        Boolean           @default(false)
  publicTokenId         String?           @unique
  publicToken           ReferrerToken?    @relation(fields: [publicTokenId], references: [id], onDelete: SetNull)
}

/// One rating submission. A response counts toward public math when `status = COUNTED`
/// -- `verified` is no longer part of the count gate (see below), only an
/// identity-established signal. The signed-in flow sets `verified: true, status:
/// COUNTED` immediately on submit, no email step, ever. The anonymous link flow
/// (`referrerTokenId` set) also counts immediately on submit (`verified` stays false --
/// there is no email verification step anymore) UNLESS submit-time anti-abuse checks
/// trip (repeat ipHash, repeat browser cookie, token over cap/revoked/expired), in which
/// case it lands `FLAGGED` instead and needs an admin's explicit approve in
/// /admin/polls/moderation before it counts -- see lib/pollResponses.ts's
/// submitAnonymousResponse. `verifyToken`/`verifyTokenExpiresAt`/`verifyEmailSentAt`
/// below are dormant leftovers of the removed email-verification flow (kept rather than
/// dropped -- no live code path writes or reads them anymore). `email` is now purely
/// optional, informational (never gates counting) and, like `ipHash` (a salted SHA-256,
/// never the raw IP -- lib/pollIntegrity.ts), must never be selected into any public page
/// or client-component prop, same rule as Reference.contactEmail elsewhere in this
/// schema. `flags` records integrity signals (token over its cap, a revoked/expired
/// token still accepted, a repeated ipHash or browser cookie on the same program) that
/// route a FLAGGED response to moderation -- see lib/pollShared.ts's POLL_FLAGS.
model PollResponse {
  id                   String             @id @default(cuid())
  programId            String
  program              Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId               String?
  email                String?
  verified             Boolean            @default(false)
  referrerTokenId      String?
  referrerToken        ReferrerToken?     @relation(fields: [referrerTokenId], references: [id])
  yearAttended         Int?
  completion           PollCompletion?
  status               PollResponseStatus @default(PENDING)
  flags                String[]           @default([])
  ipHash               String
  /// Dormant -- leftover from the removed magic-link email-verification flow. No live
  /// code path writes or reads these three columns anymore; kept rather than dropped
  /// (a destructive migration for no benefit) since historical rows may still carry
  /// values here.
  verifyToken          String?            @unique
  verifyTokenExpiresAt DateTime?
  verifyEmailSentAt    DateTime?
  /// Exactly the question ids the rating form displayed to this respondent at submit
  /// time, stamped server-side (never client input) -- moderation diffs this against
  /// `answers` to show "skipped" explicitly, and stays accurate even after a later
  /// admin edit adds/removes questions from the program's live config (unlike
  /// recomputing against the *current* config, which would misattribute a
  /// since-added question as "skipped" on old responses that never saw it).
  presentedQuestionIds String[]           @default([])
  /// Question ids the respondent explicitly marked N/A. An N/A'd question stores no
  /// PollAnswer row (absence stays the only representation of "no answer value") --
  /// this array only records that the opt-out was deliberate, so moderation can show
  /// "N/A" distinct from a question that was merely left untouched (which shows via
  /// presentedQuestionIds minus answers minus this array).
  naQuestionIds        String[]           @default([])
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  answers              PollAnswer[]
  reviews              PollReview[]

  @@index([programId, status, verified])
  @@index([programId, ipHash])
  @@index([referrerTokenId])
}

/// One answer to one question within one response. The composite PK doubles as the
/// "never answer the same question twice in one response" constraint. `value` is
/// checked 1-5 at the DB level via a hand-added CHECK constraint in this model's
/// migration (Prisma has no first-class CHECK syntax) -- see the migration.sql comment
/// for why `prisma db push` must never be used against this schema. `question` uses
/// onDelete: Restrict, not Cascade or SetNull: a PollQuestion can never be hard-deleted
/// once it has answers (retire it instead), matching the spec's "questions are retired,
/// never deleted, once responses exist."
model PollAnswer {
  responseId      String
  response        PollResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId      String
  question        PollQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionVersion Int
  value           Int

  @@id([responseId, questionId])
  @@index([questionId])
}

/// An optional, per-question free-text review, always paired with explicit consent
/// (`consentGiven` is also a hand-written DB CHECK -- see the migration -- a
/// non-consented row cannot exist even via a bug). One review per question per
/// response (`@@unique([responseId, questionId])`) -- the form renders exactly one
/// textarea per question, and editing an existing review is out of scope, so a second
/// submission for the same (response, question) pair is rejected rather than
/// overwritten. Defaults to PENDING and nothing ever auto-approves; `approvePollReview`
/// (lib/pollReviews.ts) additionally refuses unless the parent PollResponse is already
/// `COUNTED` AND `verified` -- an unverified anonymous response's reviews sit
/// unapprovable until the magic link is clicked. Rejected rows are retained, never
/// deleted. Publishing (`listPublicReviews`) is a query-time join against the parent
/// response's live status/verified, not a stored publish flag -- voiding the parent
/// response instantly hides its approved reviews with no write to this table, and
/// restoring the response republishes them automatically. `programId` is denormalized
/// (redundant with `response.programId`) purely so the public program-page query and
/// the admin queue don't need to join through PollResponse to filter by program.
model PollReview {
  id              String           @id @default(cuid())
  responseId      String
  response        PollResponse     @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId      String
  question        PollQuestion     @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionVersion Int
  programId       String
  program         Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  text            String
  consentGiven    Boolean
  consentAt       DateTime
  status          PollReviewStatus @default(PENDING)
  moderatedBy     String?
  moderatedAt     DateTime?
  moderatorNote   String?
  createdAt       DateTime         @default(now())

  @@unique([responseId, questionId])
  @@index([programId, status])
  @@index([status])
}

/// A minted outreach link (`/rate/[slug]?ref=token`) an admin hands out to a specific
/// person or group (`label`/`note` record who). `maxResponses: null` means uncapped --
/// exceeding it doesn't reject a submission, it flags the response (`token_over_cap`)
/// for moderation, same "never silently drop" posture as a revoked or expired token
/// still being accepted-and-flagged. `token` is a randomBytes(24) base64url string, same
/// generation as Folder.shareToken.
model ReferrerToken {
  id           String             @id @default(cuid())
  token        String             @unique
  programId    String
  program      Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  label        String
  note         String?
  maxResponses Int?
  expiresAt    DateTime?
  revoked      Boolean            @default(false)
  createdAt    DateTime           @default(now())
  responses    PollResponse[]
  /// Set only for the one, lazily-minted token a program's ProgramPollConfig.pollLinkPublic
  /// points at (@unique on the other side keeps this to at most one program).
  publicFor    ProgramPollConfig?

  @@index([programId])
}

/// A per-program FAQ entry -- either admin-authored (`source` "staff"/"admin"/
/// "alumni poll") or a visitor's submitted question via the program page's "Ask a
/// question" button (`source` "visitor"). Visitor rows always start `DRAFT` with
/// `answer` null; nothing publishes itself -- `lib/programFaq.ts`'s admin-only write
/// path refuses to set `PUBLISHED` while `answer` is empty. `REJECTED` exists (beyond
/// DRAFT/PUBLISHED) so a spam or out-of-scope visitor question can be dismissed
/// without hard-deleting user-submitted content -- same retain-never-delete posture as
/// `PollReview`; `deleteFaq` (lib/programFaq.ts) refuses `source: "visitor"` rows
/// entirely, only ever deleting an admin-authored draft that never had public exposure.
/// `consentGiven`/`consentAt`/`ipHash` are populated only for visitor rows (nullable
/// for admin-authored ones, which have no consent concept) -- the hand-written
/// conditional CHECK in this model's migration requires consent specifically when
/// `source = 'visitor'`, the same non-bypassable-even-by-a-bug posture as
/// `PollReview.consentGiven`'s unconditional CHECK. `ipHash` is a salted SHA-256
/// (`lib/pollIntegrity.ts`'s `hashIp`), never the raw IP, and -- like every
/// email/ipHash field in this schema -- must never be selected into a public page or
/// client-component prop.
model ProgramFAQ {
  id            String           @id @default(cuid())
  programId     String
  program       Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  question      String
  answer        String?
  status        ProgramFaqStatus @default(DRAFT)
  sortOrder     Int              @default(0)
  source        String?
  consentGiven  Boolean?
  consentAt     DateTime?
  ipHash        String?
  moderatedBy   String?
  moderatedAt   DateTime?
  moderatorNote String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([programId, status])
  @@index([status])
}
