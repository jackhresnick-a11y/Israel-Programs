// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DurationType {
  TEN_DAY
  SUMMER
  SEMESTER
  GAP_YEAR
  CUSTOM
}

enum ProgramStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum EditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactRequestStatus {
  OPEN
  REPLIED
}

model Program {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  description         String
  goodFor             String?
  logoUrl             String?
  organization        String?
  location            String?
  durationType        DurationType
  durationText        String?
  cost                String?
  signupInstructions  String?
  signupUrl           String?
  contactEmail        String?
  contactPhone        String?
  contactWebsite      String?
  status              ProgramStatus @default(PENDING)
  createdById         String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tags                Tag[]         @relation("ProgramTags")
  videos              Video[]
  reviews             Review[]
  edits               ProgramEdit[]
  references          Reference[]

  @@index([durationType])
  @@index([status])
}

model ProgramEdit {
  id            String     @id @default(cuid())
  programId     String
  program       Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  payload       String
  submittedById String
  status        EditStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  reviewedAt    DateTime?

  @@index([programId])
  @@index([status])
}

model Tag {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  programs Program[] @relation("ProgramTags")
}

model Video {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  caption   String?
  createdAt DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  programId    String
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  rating       Int
  text         String
  reviewerName String
  userId       String?
  createdAt    DateTime @default(now())

  @@index([programId])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  body      String
  updatedAt DateTime @updatedAt
}

model Reference {
  id              String           @id @default(cuid())
  programId       String
  program         Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId          String
  displayName     String
  attendedText    String
  note            String?
  contactEmail    String
  status          ProgramStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  contactRequests ContactRequest[]

  @@unique([programId, userId])
  @@index([programId])
  @@index([status])
}

model ContactRequest {
  id              String               @id @default(cuid())
  referenceId     String
  reference       Reference            @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  requesterUserId String
  requesterEmail  String
  note            String?
  status          ContactRequestStatus @default(OPEN)
  createdAt       DateTime             @default(now())

  @@unique([referenceId, requesterUserId])
  @@index([referenceId])
}
