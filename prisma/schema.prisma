// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DurationType {
  TEN_DAY
  SUMMER
  SEMESTER
  GAP_YEAR
  CUSTOM
}

enum ProgramStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum EditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactRequestStatus {
  OPEN
  REPLIED
}

enum TravelType {
  SINGLE_LOCATION
  MULTI_CITY_TOURING
}

enum FieldDecisionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Program {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  description         String
  goodFor             String?
  logoUrl             String?
  organization        String?
  location            String?
  durationType        DurationType
  durationText        String?
  cost                String?
  signupInstructions  String?
  signupUrl           String?
  contactEmail        String?
  contactPhone        String?
  contactWebsite      String?
  hasScholarship      Boolean?
  hasCollegeCredit    Boolean?
  travelType          TravelType?
  status              ProgramStatus @default(PENDING)
  createdById         String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tags                Tag[]         @relation("ProgramTags")
  videos              Video[]
  reviews             Review[]
  edits               ProgramEdit[]
  references          Reference[]

  @@index([durationType])
  @@index([status])
}

model ProgramEdit {
  id              String                     @id @default(cuid())
  programId       String
  program         Program                    @relation(fields: [programId], references: [id], onDelete: Cascade)
  payload         String
  submittedById   String
  status          EditStatus                 @default(PENDING)
  createdAt       DateTime                   @default(now())
  reviewedAt      DateTime?
  fieldDecisions  ProgramEditFieldDecision[]

  @@index([programId])
  @@index([status])
}

/// One row per changed field on a ProgramEdit, seeded from the computed diff
/// the first time a moderator opens the review screen. Tag adds/removes reuse
/// this same shape via a "tag:added:<slug>" / "tag:removed:<slug>" fieldName
/// convention rather than a second parallel structure. finalValue defaults to
/// proposedValue but a moderator can overwrite it before accepting.
model ProgramEditFieldDecision {
  id            String              @id @default(cuid())
  editId        String
  edit          ProgramEdit         @relation(fields: [editId], references: [id], onDelete: Cascade)
  fieldName     String
  proposedValue String?
  finalValue    String?
  decision      FieldDecisionStatus @default(PENDING)

  @@unique([editId, fieldName])
}

model Tag {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  category String?
  /// Display order within its category (ascending), for both the filter-bar dropdowns
  /// and the program-form tag picker. Ties (e.g. the default 0 most tags are created
  /// with) break by name -- see listAllTags's orderBy.
  order    Int       @default(0)
  programs Program[] @relation("ProgramTags")
}

/// Admin-editable registry of the category headers tags are grouped under (both in the
/// browse-page filter bar and the program-form tag picker). `Tag.category` is a soft
/// string reference to `TagCategory.slug` -- deliberately not a foreign key, so existing
/// tags and the OR-within/AND-across grouping in lib/programs.ts's buildTagAndClauses
/// keep working unchanged even for a category that has since been renamed or removed.
/// Duration and Region are NOT rows here -- Duration is a real Program column
/// (durationType) and Region is a pure UI-layer grouping over `location`-category tags
/// (see lib/regions.ts) -- neither is a Tag category.
model TagCategory {
  id           String  @id @default(cuid())
  slug         String  @unique
  label        String
  order        Int     @default(0)
  tint         String  @default("accent")
  showInFilter Boolean @default(true)
}

model Video {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  caption   String?
  createdAt DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  programId    String
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  rating       Int
  text         String
  reviewerName String
  userId       String?
  createdAt    DateTime @default(now())

  @@index([programId])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  body      String
  updatedAt DateTime @updatedAt
}

model Reference {
  id              String           @id @default(cuid())
  programId       String
  program         Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId          String
  displayName     String
  attendedText    String
  note            String?
  contactEmail    String
  status          ProgramStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  contactRequests ContactRequest[]

  @@unique([programId, userId])
  @@index([programId])
  @@index([status])
}

model ContactRequest {
  id              String               @id @default(cuid())
  referenceId     String
  reference       Reference            @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  requesterUserId String
  requesterEmail  String
  note            String?
  status          ContactRequestStatus @default(OPEN)
  createdAt       DateTime             @default(now())

  @@unique([referenceId, requesterUserId])
  @@index([referenceId])
}

/// Immutable, append-only log powering the admin xlsx export. Deliberately
/// has no foreign key to Program: a row here must survive even if the
/// underlying program is later renamed or deleted, since it's a permanent
/// historical record, not a live view of the Program table.
model ProgramExportRow {
  id        String   @id @default(cuid())
  programId String   @unique
  name      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
