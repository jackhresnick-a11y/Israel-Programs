# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# sqlite database
*.db
*.db-journal

# uploaded media (local dev storage)
/uploads

# personal working spreadsheet + its internal sync bookkeeping (contains your
# own notes in columns B+; not shared project data like the other data/*.json
# files, so it's not committed by default -- remove these lines if you'd
# rather have it tracked/backed up via git)
/data/programs.xlsx
/data/.programs-xlsx-sync-state.json

# clerk configuration (can include secrets)
/.clerk/
